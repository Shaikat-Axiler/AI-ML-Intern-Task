# ── LLM Explorer Toolkit — Environment Variables ─────────────────────────────

# OpenRouter API key (free tier available at https://openrouter.ai)
# Required for cloud models (Mistral, Llama 3, Gemma, Phi-3)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama base URL (default: local install)
# Change to a remote Ollama server if needed
OLLAMA_BASE_URL=http://localhost:11434
